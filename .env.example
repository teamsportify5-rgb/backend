# Copy this file to `.env` and fill in real values. Never commit `.env` (it is gitignored).

# Firebase Admin (push notifications) — paste the ENTIRE service account JSON as ONE line (minified).
# Generate: Firebase Console → Project settings → Service accounts → Generate new private key
# Minify locally:  node -e "console.log(JSON.stringify(require('./your-service-account.json')))"
FIREBASE_CREDENTIALS_JSON=

# Vercel Cron: long random string. Same value must be set in Vercel env for /internal/cron/order-due-reminders
CRON_SECRET=

# Optional: path to service account JSON file instead of FIREBASE_CREDENTIALS_JSON (e.g. on a VPS)
# FIREBASE_CREDENTIALS_PATH=
